{
  "name": "bloodchain-poc",
  "version": "0.1.0",
  "description": "Vein-to-vein blood custody tracking on Hedera (HTS + HCS + smart contract) - two-week proof of concept",
  "type": "module",
  "scripts": {
    "create-token": "node scripts/01-createToken.js",
    "create-topic": "node scripts/02-createTopic.js",
    "deploy-contract": "node scripts/03-deployContract.js",
    "register-parties": "node scripts/registerAllParties.js",
    "authorize-lab": "node scripts/05-authorizeLab.js",
    "rebuild-index": "node scripts/rebuildIndex.js",
    "check-index": "node scripts/rebuildIndex.js --check",
    "compile-oversight": "node scripts/compileContract.js BloodOversight",
    "deploy-oversight": "node scripts/04-deployOversight.js",
    "server": "node server/index.js",
    "demo": "node demo.js",
    "demo-oversight": "node demo-oversight.js",
    "test": "node --test test/bloodchain.test.js"
  },
  "dependencies": {
    "@hashgraph/sdk": "^2.51.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "solc": "^0.8.36"
  },
  "overrides": {
    "@grpc/grpc-js": "^1.14.4",
    "@hashgraph/sdk": {
      "protobufjs": "^8.7.1"
    },
    "@hiero-ledger/proto": {
      "protobufjs": "^7.6.5"
    }
  }
}
