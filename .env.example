## Copy this file to .env and fill in your own values. Never commit the real .env.

## Your operator account (this account pays fees, and becomes token treasury)
HEDERA_NETWORK=testnet
OPERATOR_ID=0.0.xxxxxx
OPERATOR_KEY=302e...           # DER-encoded private key from the Hedera portal

## Filled in automatically by scripts/01-createToken.js and 02-createTopic.js and 03-deployContract.js
## the scripts read these back in on later runs, so you do not have to hunt for IDs by hand
TOKEN_ID=
TOPIC_ID=
CONTRACT_ID=

## Simulated party accounts (blood bank is the operator/treasury above)
LAB_ACCOUNT_ID=0.0.xxxxxx
LAB_ACCOUNT_KEY=302e...
HOSPITAL_ACCOUNT_ID=0.0.xxxxxx
HOSPITAL_ACCOUNT_KEY=302e...
TRANSPORT_ACCOUNT_ID=0.0.xxxxxx
TRANSPORT_ACCOUNT_KEY=302e...
